# ── Foundry RPC Endpoints ──────────────────────────────────────────────
# Used in contracts/foundry.toml [rpc_endpoints]
SEPOLIA_RPC=

# ── Deployer Private Key (optional) ────────────────────────────────────
# Falls back to interactive prompt (vm.promptSecret) if not set.
# Only use for local/dev — never commit real keys!
PRIVATE_KEY=

# ── Etherscan API Key (optional) ───────────────────────────────────────
# Required for `forge script --verify` on testnet/mainnet
ETHERSCAN_API_KEY=
